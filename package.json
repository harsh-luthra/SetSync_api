{
  "name": "setsync-backend",
  "version": "1.0.0",
  "description": "SetSync backend — Node.js API server + Appwrite (film production management)",
  "main": "dist/src/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && node -e \"require('fs').cpSync('src/templates','dist/src/templates',{recursive:true})\"",
    "start": "node dist/src/index.js",
    "provision": "tsx scripts/provision.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "firebase-admin": "^12.7.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-appwrite": "^14.1.0",
    "node-cron": "^3.0.3",
    "pdf-lib": "^1.17.1",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "puppeteer": "^23.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.16.10",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
