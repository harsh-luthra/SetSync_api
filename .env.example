# --- Server ---
PORT=3000
NODE_ENV=development
# Public base URL of this API (used to build signed download links)
PUBLIC_BASE_URL=http://localhost:3000
# Comma-separated list of allowed origins, or * for any (lock down in production)
CORS_ORIGINS=*

# --- Appwrite ---
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT=your-project-id
# API key with full scopes (databases, storage, users, teams)
APPWRITE_API_KEY=your-api-key
APPWRITE_DATABASE_ID=setsync_db
# Free plan allows only ONE bucket — leave these unset to share the 'scripts'
# bucket (per-file permissions keep scripts server-only, call sheets team-read).
#APPWRITE_BUCKET_SCRIPTS=scripts
#APPWRITE_BUCKET_CALLSHEETS=callsheets
#APPWRITE_BUCKET_AVATARS=avatars

# --- Firebase Cloud Messaging ---
# Either the raw service-account JSON (single line) or an absolute path to the file.
# Leave empty to disable push (in-app notification documents still work).
FCM_SERVICE_ACCOUNT_JSON=

# --- Security ---
# HMAC secret for rotating attendance QR tokens (long random string)
QR_HMAC_SECRET=change-me-to-a-long-random-secret
# Optional separate secret for signed download URLs (defaults to QR_HMAC_SECRET)
URL_SIGN_SECRET=
# Comma-separated emails allowed to use the master-admin endpoints
# (create the account with: npx tsx scripts/create-master-admin.ts)
MASTER_ADMIN_EMAILS=
# Optional: secret for external cron pings (POST /jobs/run/:job, X-Cron-Secret header).
# Needed on free-tier hosts that sleep (Render) — schedule cron-job.org to call:
#   20:00 IST -> /api/v1/jobs/run/tomorrowReminder
#   00:05 IST -> /api/v1/jobs/run/midnightWrap
CRON_TRIGGER_SECRET=
