# --- Server ---
PORT=3000
NODE_ENV=development
# Public base URL of this API (used to build signed download links). Falls back to request host.
PUBLIC_BASE_URL=http://localhost:3000
# Comma-separated list of allowed origins, or * for any (lock down in production)
CORS_ORIGINS=*

# --- Appwrite ---
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT=your-project-id
# API key with full scopes (databases, storage, users, teams)
APPWRITE_API_KEY=your-api-key
APPWRITE_DATABASE_ID=setsync_db
# Free plan allows only ONE bucket — leave these unset to share the 'scripts'
# bucket (per-file permissions keep scripts server-only, call sheets team-read).
# On a paid plan, set three distinct bucket IDs and re-run provision.
#APPWRITE_BUCKET_SCRIPTS=scripts
#APPWRITE_BUCKET_CALLSHEETS=callsheets
#APPWRITE_BUCKET_AVATARS=avatars

# --- Firebase Cloud Messaging ---
# Either the raw service-account JSON (single line) or an absolute path to the JSON file.
# Leave empty to disable push (in-app notification documents are still created).
FCM_SERVICE_ACCOUNT_JSON=\setsync-admin.json

# --- Security ---
# HMAC secret for rotating attendance QR tokens (min 16 chars, use a long random string)
QR_HMAC_SECRET=change-me-to-a-long-random-secret
# Optional separate secret for signed download URLs (defaults to QR_HMAC_SECRET)
URL_SIGN_SECRET=
# Comma-separated emails allowed to use the master-admin endpoints
# (create the account with: npx tsx scripts/create-master-admin.ts)
MASTER_ADMIN_EMAILS=

# --- Provision seeding (optional, used by `npm run provision`) ---
# When set, provision creates a demo project + Appwrite team + director invite.
SEED_PROJECT_TITLE=
SEED_PRODUCTION_HOUSE=
SEED_DIRECTOR_NAME=
SEED_DIRECTOR_PHONE=
